# Environment Variables Reference
#
# This file documents all environment variables used across services.
# In production, set these via Dokploy UI → Environment Variables tab.
# For local development, copy this file to .env and fill in values.

# ========================
# Database (Dokploy Database Service)
# ========================
# In Dokploy: use the internal hostname shown in the Database service settings
DATABASE_URL=postgresql://appuser:changeme@DOKPLOY_DB_HOSTNAME:5432/appdb

# ========================
# Database (Individual settings for services/api)
# ========================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# ========================
# Auth Service (FastAPI JWT)
# ========================
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# ========================
# AI Service
# ========================
AI_MODEL_PROVIDER=mock        # Options: mock, openai, anthropic, gemini
AI_MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-key
MOCK_LLM_URL=http://localhost:8001/v1

# AI Tracing & Sessions (Stored in Postgres)
EVAL_SAMPLE_RATE=1.0          # 1.0 = 100% (dev), 0.05 = 5% (production)

# RAG / Vector DB (Optional)
QDRANT_URL=
QDRANT_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_MODEL=keepitreal/vietnamese-sbert


# ========================
# Frontend (Build-time vars for Vite)
# ========================
VITE_API_URL=https://api.yourdomain.com

VITE_WS_URL=wss://api.yourdomain.com/ws

# ========================
# Environment
# ========================
PYTHON_ENV=development        # development | production
NODE_ENV=development          # development | production
